# ============================================
# 智扫通机器人智能客服 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# 通义千问 DashScope API 密钥 (必填)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 聊天模型名称 (可选, 默认 qwen3-max)
CHAT_MODEL_NAME=qwen3-max

# 嵌入模型名称 (可选, 默认 text-embedding-v4)
EMBEDDING_MODEL_NAME=text-embedding-v4

# 天气 API 提供商 (可选, 默认 wttr, 可选: wttr | openweather)
WEATHER_API_PROVIDER=wttr

# OpenWeatherMap API Key (当 WEATHER_API_PROVIDER=openweather 时需要)
# 获取地址: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# 日志级别 (可选, 默认 INFO)
LOG_LEVEL=INFO
